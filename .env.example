# ===========================================
# Noura Driving School Slot Checker - Config
# ===========================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# --- Portal credentials ---
NOURA_EMAIL=your-email@example.com
NOURA_PASSWORD=your-password

# --- Notifications ---
# Email to receive slot alerts
NOTIFY_EMAIL=your-email@example.com

# SMTP (Gmail example - use App Password: https://support.google.com/accounts/answer/185833)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Alternative: Outlook
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587

# --- Check interval (minutes) ---
CHECK_INTERVAL_MIN=5

# --- Playwright ---
# Set to false for visible browser (debug)
PLAYWRIGHT_HEADLESS=true
